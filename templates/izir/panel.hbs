<div class="izir-panel {{densityClass}}">
  <section class="izir-roster">
    <header class="izir-roster-head">
      <h3>{{localize "SHARDS.Izir.Roster"}}</h3>
      <button type="button" class="izir-mark-btn" data-action="markSelected"
        data-tooltip="{{localize 'SHARDS.Izir.MarkSelectedHint'}}">
        <i class="fa-solid fa-plus"></i> {{localize "SHARDS.Izir.MarkSelected"}}
      </button>
    </header>

    {{#if hasRoster}}
    <ul class="izir-roster-list">
      {{#each roster}}
      <li class="izir-roster-item tier-{{this.tierId}} {{#if this.selected}}selected{{/if}}"
        data-action="selectActor" data-actor="{{this.uuid}}">
        <img src="{{this.img}}" alt="" />
        <div class="izir-roster-meta">
          <span class="izir-roster-name">{{this.name}}</span>
          <span class="izir-roster-tier">{{this.tierLabel}} · {{localize 'SHARDS.Izir.LevelShort'}}&nbsp;{{this.level}}</span>
        </div>
        {{#if this.terminal}}<i class="fa-solid fa-skull izir-dot izir-dot-terminal"></i>{{/if}}
        {{#if this.pending}}<i class="fa-solid fa-hourglass-half izir-dot izir-dot-pending"
          data-tooltip="{{localize 'SHARDS.Izir.PendingTemptation'}}"></i>{{/if}}
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="izir-empty">{{localize "SHARDS.Izir.NoMarked"}}</p>
    {{/if}}
  </section>

  <section class="izir-detail">
    {{#if detail}}
    <header class="izir-detail-head tier-{{detail.tierId}}">
      <img src="{{detail.img}}" alt="" />
      <div class="izir-detail-title">
        <h2>{{detail.name}}</h2>
        <span class="izir-tier-banner">{{detail.tierLabel}}</span>
      </div>
      <button type="button" class="izir-unmark" data-action="unmark" data-actor="{{detail.uuid}}"
        data-tooltip="{{localize 'SHARDS.Izir.Unmark'}}"><i class="fa-solid fa-user-xmark"></i></button>
    </header>

    <nav class="izir-tabs">
      <button type="button" data-action="tab" data-tab="overview"
        class="{{#if isOverview}}active{{/if}}">{{localize "SHARDS.Izir.TabOverview"}}</button>
      <button type="button" data-action="tab" data-tab="effects"
        class="{{#if isEffects}}active{{/if}}">{{localize "SHARDS.Izir.TabEffects"}}</button>
      <button type="button" data-action="tab" data-tab="temptation"
        class="{{#if isTemptation}}active{{/if}}">{{localize "SHARDS.Izir.TabTemptation"}}</button>
      <button type="button" data-action="tab" data-tab="art"
        class="{{#if isArt}}active{{/if}}">{{localize "SHARDS.Izir.TabArt"}}</button>
      <button type="button" data-action="tab" data-tab="history"
        class="{{#if isHistory}}active{{/if}}">{{localize "SHARDS.Izir.TabHistory"}}</button>
    </nav>

    {{#if isOverview}}
    <div class="izir-overview">
      <div class="izir-stepper">
        <button type="button" data-action="levelDown" data-actor="{{detail.uuid}}"
          {{#unless detail.canDown}}disabled{{/unless}}><i class="fa-solid fa-minus"></i></button>
        <div class="izir-level-display">
          <span class="izir-level-num">{{detail.level}}</span>
          <span class="izir-level-max">/ {{detail.maxLevel}}</span>
          <span class="izir-level-caption">{{localize "SHARDS.Izir.Immersion"}}</span>
        </div>
        <button type="button" data-action="levelUp" data-actor="{{detail.uuid}}"
          {{#unless detail.canUp}}disabled{{/unless}}><i class="fa-solid fa-plus"></i></button>
      </div>

      {{#if detail.terminal}}
      <div class="izir-terminal-banner terminal-{{detail.terminal}}">
        {{#if (shardsEq detail.terminal "nineveh")}}
        {{localize "SHARDS.Izir.TerminalNineveh"}}
        {{else}}
        {{localize "SHARDS.Izir.TerminalSubjugated"}}
        {{/if}}
      </div>
      {{/if}}

      <dl class="izir-stat-grid">
        <div>
          <dt>{{localize "SHARDS.Izir.TemptationDC"}}</dt>
          <dd>{{detail.dcPreview}}</dd>
        </div>
        <div>
          <dt>{{localize "SHARDS.Izir.Suppressed"}}</dt>
          <dd>{{detail.suppressedCount}}</dd>
        </div>
      </dl>
    </div>
    {{/if}}

    {{#if isEffects}}
    <div class="izir-effects">
      <p class="izir-effects-hint">{{localize "SHARDS.Izir.EffectsHint"}}</p>
      {{#if effects.hasAny}}
      {{#each effects.groups}}
      <div class="izir-effect-group tier-{{this.tierId}}">
        <h4 class="izir-effect-group-label">{{this.label}}</h4>
        {{#each this.rows}}
        <div class="izir-effect-row status-{{this.status}} {{#if this.isBane}}is-bane{{else}}is-boon{{/if}}">
          <span class="izir-effect-kind" data-tooltip="{{#if this.isBane}}{{localize 'SHARDS.Izir.Bane'}}{{else}}{{localize 'SHARDS.Izir.Boon'}}{{/if}}">
            <i class="fa-solid {{#if this.isBane}}fa-skull-crossbones{{else}}fa-bolt{{/if}}"></i>
          </span>
          <span class="izir-effect-name">{{this.name}}</span>
          <span class="izir-effect-status">
            {{#if this.suppressed}}{{localize "SHARDS.Izir.StatusSuppressed"}}
            {{else if this.unlocked}}{{localize "SHARDS.Izir.StatusActive"}}
            {{else}}{{#if this.gate}}{{localize "SHARDS.Izir.UnlockSubjugation"}}{{else}}{{localize "SHARDS.Izir.UnlockAt"}}&nbsp;{{this.unlockLevel}}{{/if}}{{/if}}
          </span>
          {{#if this.reason}}<span class="izir-effect-reason" data-tooltip="{{this.reason}}"><i class="fa-solid fa-comment-dots"></i></span>{{/if}}
          <span class="izir-effect-controls">
            {{#if this.isBane}}
            <button type="button" class="izir-icon-btn {{#if this.revealed}}on{{/if}}" data-action="toggleReveal" data-family="{{this.family}}"
              data-tooltip="{{#if this.revealed}}{{localize 'SHARDS.Izir.Hide'}}{{else}}{{localize 'SHARDS.Izir.Reveal'}}{{/if}}">
              <i class="fa-solid {{#if this.revealed}}fa-eye{{else}}fa-eye-slash{{/if}}"></i>
            </button>
            {{/if}}
            <button type="button" class="izir-icon-btn" data-action="editReason" data-family="{{this.family}}"
              data-tooltip="{{localize 'SHARDS.Izir.ReasonEdit'}}"><i class="fa-solid fa-pen"></i></button>
            <button type="button" class="izir-icon-btn {{#if this.suppressed}}on{{/if}}" data-action="toggleSuppress" data-family="{{this.family}}"
              data-tooltip="{{#if this.suppressed}}{{localize 'SHARDS.Izir.Unsuppress'}}{{else}}{{localize 'SHARDS.Izir.Suppress'}}{{/if}}">
              <i class="fa-solid {{#if this.suppressed}}fa-toggle-off{{else}}fa-toggle-on{{/if}}"></i>
            </button>
          </span>
        </div>
        {{/each}}
      </div>
      {{/each}}
      {{else}}
      <p class="izir-empty">{{localize "SHARDS.Izir.NoEffectsYet"}}</p>
      {{/if}}
    </div>
    {{/if}}

    {{#if isTemptation}}
    <div class="izir-temptation">
      <div class="izir-tempt-head">
        <span class="izir-tempt-dc">{{localize "SHARDS.Izir.TemptationDC"}}: <strong>{{temptation.dc}}</strong></span>
        <button type="button" class="izir-tempt-btn" data-action="tempt">
          <i class="fa-solid fa-hand-sparkles"></i> {{localize "SHARDS.Izir.TemptationTrigger"}}
        </button>
      </div>

      {{#if temptation.pending}}
      <div class="izir-pending">
        <p><i class="fa-solid fa-hourglass-half"></i> {{localize "SHARDS.Izir.PendingTitle"}} — DC {{temptation.pending.dc}}</p>
        {{#if temptation.pending.reason}}<p class="izir-card-reason"><em>{{temptation.pending.reason}}</em></p>{{/if}}
        <div class="izir-outcome-buttons">
          <span class="izir-outcome-label">{{localize "SHARDS.Izir.RecordManually"}}</span>
          {{#each temptation.outcomes}}
          <button type="button" class="izir-outcome-btn outcome-{{this.key}}" data-action="recordOutcome" data-outcome="{{this.key}}">{{this.label}}</button>
          {{/each}}
          <button type="button" class="izir-icon-btn" data-action="clearPending" data-tooltip="{{localize 'SHARDS.Izir.ClearPending'}}"><i class="fa-solid fa-xmark"></i></button>
        </div>
      </div>
      {{/if}}

      {{#if temptation.chips.length}}
      <div class="izir-chips">
        <span class="izir-chips-label">{{localize "SHARDS.Izir.Suggestions"}}</span>
        {{#each temptation.chips}}
        <button type="button" class="izir-chip" data-action="chip" data-chip="{{this.chip}}">{{this.label}}</button>
        {{/each}}
      </div>
      {{/if}}

      <div class="izir-tempt-recent">
        <h4>{{localize "SHARDS.Izir.RecentRolls"}}</h4>
        {{#if temptation.recent.length}}
        <ul>
          {{#each temptation.recent}}
          <li>
            <span class="izir-outcome-pill outcome-{{this.outcomeClass}}">{{this.outcome}}</span>
            <span class="izir-tempt-when">DC {{this.dc}} · {{this.when}}</span>
            {{#if this.reason}} — <em>{{this.reason}}</em>{{/if}}
          </li>
          {{/each}}
        </ul>
        {{else}}
        <p class="izir-empty">{{localize "SHARDS.Izir.NoRollsYet"}}</p>
        {{/if}}
      </div>
    </div>
    {{/if}}

    {{#if isArt}}
    <div class="izir-art">
      <p class="izir-effects-hint">{{localize "SHARDS.Izir.ArtHint"}}</p>
      {{#each art.rows}}
      <div class="izir-art-row {{#if this.applied}}applied{{/if}}">
        <div class="izir-art-row-head">
          <strong>{{this.label}}</strong>
          {{#if this.applied}}<span class="izir-art-applied">{{localize "SHARDS.Izir.ArtApplied"}}</span>{{/if}}
        </div>
        <div class="izir-art-field">
          <label>{{localize "SHARDS.Izir.ArtPortrait"}}</label>
          <span class="izir-art-path">{{#if this.portrait}}{{this.portrait}}{{else}}—{{/if}}</span>
          <button type="button" class="izir-icon-btn" data-action="artBrowse" data-threshold="{{this.threshold}}" data-field="portrait"
            data-tooltip="{{localize 'SHARDS.Izir.ArtBrowse'}}"><i class="fa-solid fa-folder-open"></i></button>
        </div>
        <div class="izir-art-field">
          <label>{{localize "SHARDS.Izir.ArtToken"}}</label>
          <span class="izir-art-path">{{#if this.token}}{{this.token}}{{else}}—{{/if}}</span>
          <button type="button" class="izir-icon-btn" data-action="artBrowse" data-threshold="{{this.threshold}}" data-field="token"
            data-tooltip="{{localize 'SHARDS.Izir.ArtBrowse'}}"><i class="fa-solid fa-folder-open"></i></button>
        </div>
        <div class="izir-art-actions">
          <button type="button" data-action="artApply" data-threshold="{{this.threshold}}" {{#unless this.hasArt}}disabled{{/unless}}>{{localize "SHARDS.Izir.ArtApply"}}</button>
          <button type="button" class="izir-icon-btn" data-action="artClear" data-threshold="{{this.threshold}}"
            data-tooltip="{{localize 'SHARDS.Izir.ArtClear'}}"><i class="fa-solid fa-eraser"></i></button>
        </div>
      </div>
      {{/each}}
      {{#if art.hasOriginal}}
      <button type="button" class="izir-art-revert" data-action="artRevert">
        <i class="fa-solid fa-rotate-left"></i> {{localize "SHARDS.Izir.ArtRevert"}}
      </button>
      {{/if}}
    </div>
    {{/if}}

    {{#if isHistory}}
    <div class="izir-history">
      <div class="izir-history-head">
        <h4>{{localize "SHARDS.Izir.HistoryTitle"}}</h4>
        <button type="button" class="izir-icon-btn" data-action="exportJournal">
          <i class="fa-solid fa-book"></i> {{localize "SHARDS.Izir.ExportJournal"}}
        </button>
      </div>
      {{#if history.hasEntries}}
      <ul class="izir-log">
        {{#each history.entries}}
        <li class="log-{{this.type}}">
          <span class="izir-log-when">{{this.when}}</span>
          <span class="izir-log-desc">{{this.desc}}{{#if this.note}} — <em>{{this.note}}</em>{{/if}}</span>
        </li>
        {{/each}}
      </ul>
      {{else}}
      <p class="izir-empty">{{localize "SHARDS.Izir.NoHistory"}}</p>
      {{/if}}
    </div>
    {{/if}}
    {{else}}
    <p class="izir-empty izir-detail-empty">{{localize "SHARDS.Izir.SelectPrompt"}}</p>
    {{/if}}
  </section>
</div>
